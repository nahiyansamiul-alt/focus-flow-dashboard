{
  "appId": "com.focusflow.app",
  "productName": "FocusFlow",
  "directories": {
    "buildResources": "public",
    "output": "dist_electron"
  },
  "files": [
    "dist/**/*",
    "electron/**/*",
    "backend/**/*",
    "!backend/node_modules/**/*",
    "!backend/*.db",
    "!backend/*.db-*",
    "!backend/*.sqlite",
    "!backend/*.sqlite-*",
    "node_modules/**/*",
    "package.json"
  ],
  "asarUnpack": [
    "backend/**",
    "node_modules/sqlite3/**"
  ],
  "afterPack": "scripts/after-pack.cjs",
  "publish": {
    "provider": "github",
    "owner": "CWE-119",
    "repo": "focus-flow-dashboard",
    "releaseType": "draft"
  },
  "win": {
    "target": [
      {
        "target": "nsis",
        "arch": [
          "x64"
        ]
      },
      {
        "target": "portable",
        "arch": [
          "x64"
        ]
      }
    ],
    "icon": "public/FucosFlow.ico"
  },
  "nsis": {
    "oneClick": false,
    "allowToChangeInstallationDirectory": true,
    "createDesktopShortcut": true,
    "createStartMenuShortcut": true
  },
  "mac": {
    "target": [
      "dmg",
      "zip"
    ],
    "icon": "public/FucosFlow.ico"
  },
  "linux": {
    "target": [
      "AppImage",
      "deb"
    ],
    "icon": "FucosFlow.png"
  }
}
